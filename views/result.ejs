<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ผลคะแนนสอบ — โรงเรียนอรพิมพ์วิทยา</title>
    <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;500;600;700&family=Noto+Serif+Thai:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        :root {
            --navy: #0f1f3d;
            --navy-light: #1a3260;
            --gold: #c9a84c;
            --gold-light: #e8c96a;
            --gold-pale: rgba(201,168,76,0.12);
            --white: #ffffff;
            --border: rgba(201,168,76,0.2);
        }

        body {
            font-family: 'Sarabun', sans-serif;
            background-color: var(--navy);
            min-height: 100vh;
            display: flex;
            align-items: flex-start;
            justify-content: center;
            padding: 2.5rem 1.5rem;
            position: relative;
            overflow-x: hidden;
        }

        body::before {
            content: '';
            position: fixed;
            inset: 0;
            background:
                radial-gradient(ellipse 70% 50% at 15% 5%, rgba(201,168,76,0.07) 0%, transparent 60%),
                linear-gradient(160deg, #0a1628 0%, #0f1f3d 50%, #07121e 100%);
            z-index: 0;
        }

        body::after {
            content: '';
            position: fixed;
            inset: 0;
            background-image:
                linear-gradient(rgba(201,168,76,0.035) 1px, transparent 1px),
                linear-gradient(90deg, rgba(201,168,76,0.035) 1px, transparent 1px);
            background-size: 48px 48px;
            z-index: 0;
        }

        .page-wrapper {
            position: relative;
            z-index: 1;
            width: 100%;
            max-width: 540px;
        }

        /* ── Header Card ── */
        .header-card {
            background: linear-gradient(135deg, rgba(201,168,76,0.15) 0%, rgba(201,168,76,0.05) 100%);
            border: 1px solid rgba(201,168,76,0.35);
            border-radius: 20px 20px 0 0;
            padding: 2rem 2rem 1.8rem;
            text-align: center;
            position: relative;
            overflow: hidden;
            animation: fadeDown 0.6s ease both;
        }

        .header-card::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0;
            height: 3px;
            background: linear-gradient(90deg, transparent, var(--gold), var(--gold-light), var(--gold), transparent);
        }

        .school-label {
            font-size: 0.72rem;
            font-weight: 600;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: var(--gold);
            margin-bottom: 0.6rem;
            opacity: 0.85;
        }

        .student-name {
            font-family: 'Noto Serif Thai', serif;
            font-size: 1.7rem;
            font-weight: 700;
            color: var(--white);
            line-height: 1.3;
            margin-bottom: 0.9rem;
        }

        .meta-row {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            flex-wrap: wrap;
        }

        .badge {
            display: inline-flex;
            align-items: center;
            gap: 0.35rem;
            padding: 0.35rem 0.85rem;
            background: rgba(255,255,255,0.06);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 100px;
            font-size: 0.8rem;
            color: rgba(255,255,255,0.7);
            white-space: nowrap;
        }

        .badge strong {
            color: var(--gold-light);
            font-weight: 600;
        }

        .plan-badge {
            padding: 0.35rem 1rem;
            background: var(--gold-pale);
            border: 1px solid rgba(201,168,76,0.4);
            border-radius: 100px;
            font-size: 0.8rem;
            color: var(--gold-light);
            font-weight: 600;
            margin-top: 0.5rem;
        }

        /* ── Scores Card ── */
        .scores-card {
            background: rgba(255,255,255,0.03);
            border: 1px solid var(--border);
            border-top: none;
            padding: 1.8rem 2rem;
            animation: fadeUp 0.6s 0.1s ease both;
        }

        .section-title {
            font-size: 0.72rem;
            font-weight: 700;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: rgba(255,255,255,0.35);
            margin-bottom: 1.1rem;
        }

        .score-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0.75rem;
        }

        .score-item {
            background: rgba(255,255,255,0.04);
            border: 1px solid rgba(255,255,255,0.07);
            border-radius: 12px;
            padding: 0.9rem 1rem;
            display: flex;
            flex-direction: column;
            gap: 0.4rem;
            transition: border-color 0.2s, background 0.2s;
            animation: fadeUp 0.5s ease both;
        }

        .score-item:hover {
            border-color: rgba(201,168,76,0.3);
            background: rgba(201,168,76,0.04);
        }

        .score-item:nth-child(1) { animation-delay: 0.15s; }
        .score-item:nth-child(2) { animation-delay: 0.20s; }
        .score-item:nth-child(3) { animation-delay: 0.25s; }
        .score-item:nth-child(4) { animation-delay: 0.30s; }
        .score-item:nth-child(5) { animation-delay: 0.35s; }
        .score-item:nth-child(6) { animation-delay: 0.40s; }
        .score-item:nth-child(7) { animation-delay: 0.45s; }
        .score-item:nth-child(8) { animation-delay: 0.50s; }

        .subject-label {
            font-size: 0.75rem;
            color: rgba(255,255,255,0.45);
            font-weight: 500;
        }

        .score-value {
            font-family: 'Noto Serif Thai', serif;
            font-size: 1.55rem;
            font-weight: 700;
            color: var(--white);
            line-height: 1;
        }

        /* ── Total Card ── */
        .total-card {
            background: linear-gradient(135deg, rgba(201,168,76,0.18) 0%, rgba(201,168,76,0.07) 100%);
            border: 1px solid rgba(201,168,76,0.4);
            border-top: none;
            padding: 1.5rem 2rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            animation: fadeUp 0.6s 0.55s ease both;
        }

        .total-label {
            font-size: 0.9rem;
            font-weight: 600;
            color: var(--gold-light);
            letter-spacing: 0.04em;
        }

        .total-value {
            font-family: 'Noto Serif Thai', serif;
            font-size: 2rem;
            font-weight: 700;
            color: var(--gold-light);
            text-shadow: 0 0 24px rgba(201,168,76,0.35);
        }

        .total-value span {
            font-size: 0.85rem;
            font-weight: 400;
            font-family: 'Sarabun', sans-serif;
            color: rgba(201,168,76,0.65);
            margin-left: 0.3rem;
        }

        /* ── Back Button ── */
        .back-wrap {
            border: 1px solid var(--border);
            border-top: none;
            border-radius: 0 0 20px 20px;
            padding: 1.2rem 2rem;
            background: rgba(0,0,0,0.15);
            animation: fadeUp 0.6s 0.6s ease both;
        }

        .btn-back {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            color: rgba(255,255,255,0.45);
            text-decoration: none;
            font-size: 0.85rem;
            font-weight: 500;
            transition: color 0.2s;
        }

        .btn-back:hover {
            color: var(--gold-light);
        }

        .btn-back::before {
            content: '←';
            font-size: 1rem;
        }

        /* Animations */
        @keyframes fadeDown {
            from { opacity: 0; transform: translateY(-16px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        @keyframes fadeUp {
            from { opacity: 0; transform: translateY(16px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        @media (max-width: 480px) {
            .score-grid { grid-template-columns: 1fr 1fr; }
            .student-name { font-size: 1.4rem; }
            .scores-card, .header-card { padding-left: 1.4rem; padding-right: 1.4rem; }
            .total-card { padding-left: 1.4rem; padding-right: 1.4rem; }
            .back-wrap { padding-left: 1.4rem; }
        }
    </style>
</head>
<body>

<div class="page-wrapper">

    <!-- Header -->
    <div class="header-card">
        <div class="school-label">โรงเรียนอรพิมพ์วิทยา · ผลการสอบวัดความรู้พื้นฐาน</div>
        <div class="student-name"><%= data.score_name %></div>
        <div class="meta-row">
            <div class="badge">ชั้น ม.<strong><%= data.classs %>/<%= data.room %></strong></div>
            <div class="badge">รหัส <strong><%= data.score_id %></strong></div>
        </div>
        <div class="meta-row" style="margin-top:0.6rem;">
            <div class="plan-badge">
                แผนการเรียน:
                <% if (data.pan == "m1") { %>ทั่วไป
                <% } else if (data.pan == "m41") { %>วิทยาศาสตร์-คณิตศาสตร์
                <% } else if (data.pan == "m42") { %>คณิตศาสตร์-วิทยาศาสตร์และเทคโนโลยี
                <% } else { %>ช่างทั่วไป<% } %>
            </div>
        </div>
    </div>

    <!-- Scores -->
    <div class="scores-card">
        <div class="section-title">คะแนนรายวิชา</div>
        <div class="score-grid">

            <div class="score-item">
                <div class="subject-label">ภาษาไทย</div>
                <div class="score-value"><%= data.score_t %></div>
            </div>

            <div class="score-item">
                <div class="subject-label">คณิตศาสตร์</div>
                <div class="score-value"><%= data.score_m %></div>
            </div>

            <div class="score-item">
                <div class="subject-label">วิทยาศาสตร์</div>
                <div class="score-value"><%= data.score_sc %></div>
            </div>

            <div class="score-item">
                <div class="subject-label">สังคมศึกษา</div>
                <div class="score-value"><%= data.score_s %></div>
            </div>

            <div class="score-item">
                <div class="subject-label">สุขศึกษา</div>
                <div class="score-value"><%= data.score_su %></div>
            </div>

            <div class="score-item">
                <div class="subject-label">ศิลปะ</div>
                <div class="score-value"><%= data.score_a %></div>
            </div>

            <div class="score-item">
                <div class="subject-label">การงานอาชีพ</div>
                <div class="score-value"><%= data.score_w %></div>
            </div>

            <div class="score-item">
                <div class="subject-label">ภาษาอังกฤษ</div>
                <div class="score-value"><%= data.score_e %></div>
            </div>

        </div>
    </div>

    <!-- Total -->
    <div class="total-card">
        <div class="total-label">คะแนนรวมทั้งหมด</div>
        <div class="total-value"><%= data.scoresum %><span>คะแนน</span></div>
    </div>

    <!-- Back -->
    <div class="back-wrap">
        <a href="/searchscore" class="btn-back">กลับไปหน้าค้นหา</a>
    </div>

</div>

</body>
</html>