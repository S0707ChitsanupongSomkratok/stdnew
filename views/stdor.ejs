                <% }) %>
            </tbody>
        </table>
      </div>
      <!-- <button class="add-row-btn" onclick="addRow('tbody-2')">＋ เพิ่มแถว</button> -->
    </div>

    <!-- Section 3 -->
    <div class="section">
      <div class="section-header">
        <div class="section-bar"></div>
        <div class="section-title">ชั้นมัธยมศึกษาปีที่ 4 แผนการเรียน คณิตศาสตร์-วิทยาศาสตร์และเทคโนโลยี</div>
