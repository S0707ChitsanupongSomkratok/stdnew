                </tr>
            <% }) %>
            </tbody>
        </table>
      </div>
      <!-- <button class="add-row-btn" onclick="addRow('tbody-1')">＋ เพิ่มแถว</button> -->
    </div>

    <!-- Section 2 -->
    <div class="section">
