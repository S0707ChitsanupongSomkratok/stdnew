<!DOCTYPE html>
<html>
<head>

<link href="https://fonts.googleapis.com/css2?family=Sarabun&display=swap" rel="stylesheet">

<style>

body{
    font-family:Sarabun;
    padding:40px;
}

.section{
    margin-bottom:50px;
}

h2{
    background:#eee;
    padding:10px;
}

table{
    width:100%;
    border-collapse: collapse;
    margin-top:10px;
}

th,td{
    border:1px solid #ccc;
    padding:8px;
    text-align:center;
}

button{
    padding:5px 10px;
    cursor:pointer;
}

</style>

</head>
<body>

<h1>รายชื่อผู้สมัคร</h1>


<!-- ================== ม.1 ================== -->

<div class="section">

    <h2>แผน ม.1</h2>

    <table>

        <tr>
            <th>รหัสประจำตัวผู้สมัคร</th>
            <th>ชื่อ</th>
            <th>เบอร์โทร</th>
            <th>ความสามารถพิเศษ</th>
            <th>จัดการ</th>
        </tr>

        <% data.m1.forEach(function(std){ %>

        <tr>

            <td><%= std.id %></td>

            <td>
                <%= std.prefix %>
                <%= std.firstname %>
                <%= std.lastname %>
            </td>
            <td><%= std.tel %></td>
            <td><%= std.skill %></td>


            <td>
                <a href="/edit/<%= std.id %>">
                    <button>แก้ไข</button>
                </a>

                <a href="/print/<%= std.id %>">
                    <button>Print</button>
                </a>
            </td>

        </tr>

        <% }) %>

    </table>

</div>



