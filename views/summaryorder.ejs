<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>สรุปยอดสั่งเสื้อ</title>
  <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;600;700&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --yellow: #F5C518;
      --yellow-light: #FFF8DC;
      --yellow-dark: #C9A000;
      --navy: #1A2E5A;
      --navy-light: #EEF2FF;
      --navy-mid: #3B5998;
      --green: #2D7D46;
      --green-light: #E8F5ED;
      --green-dark: #1A5C30;
      --gray-50: #F9FAFB;
      --gray-100: #F3F4F6;
      --gray-200: #E5E7EB;
      --gray-400: #9CA3AF;
      --gray-700: #374151;
      --gray-900: #111827;
      --shadow: 0 4px 24px rgba(0,0,0,0.08);
      --radius: 16px;
    }

    body {
      font-family: 'Sarabun', sans-serif;
      background: #F0F4F8;
      color: var(--gray-900);
      min-height: 100vh;
      padding: 32px 16px 64px;
    }

    header {
      text-align: center;
      margin-bottom: 40px;
    }

    header h1 {
      font-size: 2rem;
      font-weight: 700;
      color: var(--gray-900);
    }

    header p {
      color: var(--gray-400);
      font-size: 0.95rem;
      margin-top: 6px;
    }

    .tables-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 28px;
      max-width: 1100px;
      margin: 0 auto;
    }

    .card {
      background: #fff;
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      overflow: hidden;
    }

    .card-header {
      padding: 20px 24px 16px;
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .card-icon {
      width: 44px;
      height: 44px;
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.3rem;
      flex-shrink: 0;
    }

    .card-title { font-size: 1.05rem; font-weight: 700; }
    .card-subtitle { font-size: 0.78rem; margin-top: 2px; opacity: 0.6; }

    .card--yellow .card-header { background: var(--yellow-light); border-bottom: 2px solid var(--yellow); }
    .card--yellow .card-icon   { background: var(--yellow); color: #000; }
    .card--yellow .card-title  { color: var(--yellow-dark); }

    .card--navy .card-header { background: var(--navy-light); border-bottom: 2px solid var(--navy-mid); }
    .card--navy .card-icon   { background: var(--navy); color: #fff; }
    .card--navy .card-title  { color: var(--navy); }

    .card--green .card-header { background: var(--green-light); border-bottom: 2px solid var(--green); }
    .card--green .card-icon   { background: var(--green); color: #fff; }
    .card--green .card-title  { color: var(--green-dark); }

    table { width: 100%; border-collapse: collapse; }

    thead th {
      padding: 10px 20px;
      font-size: 0.78rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      color: var(--gray-400);
      background: var(--gray-50);
      border-bottom: 1px solid var(--gray-200);
      text-align: left;
    }

    thead th:last-child { text-align: right; }

    tbody tr {
      border-bottom: 1px solid var(--gray-100);
      transition: background 0.15s;
    }

    tbody tr:last-child { border-bottom: none; }
    tbody tr:hover { background: var(--gray-50); }

    tbody td { padding: 11px 20px; font-size: 0.95rem; }
    tbody td:first-child { font-weight: 600; color: var(--gray-700); }
    tbody td:last-child  { text-align: right; }

    .badge {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 36px;
      padding: 3px 10px;
      border-radius: 20px;
      font-size: 0.9rem;
      font-weight: 700;
    }

    .badge--zero   { background: var(--gray-100); color: var(--gray-400); }
    .badge--yellow { background: var(--yellow);    color: #000; }
    .badge--navy   { background: var(--navy-light); color: var(--navy); }
    .badge--green  { background: var(--green-light); color: var(--green-dark); }

    .card-footer {
      padding: 12px 20px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      background: var(--gray-50);
      border-top: 1px solid var(--gray-200);
    }

    .card-footer span  { font-size: 0.82rem; color: var(--gray-400); }
    .card-footer strong { font-size: 1rem; font-weight: 700; color: var(--gray-900); }
  </style>
</head>
<body>

<header>
  <h1>📋 สรุปยอดสั่งเสื้อ</h1>
  <p>ข้อมูลจากระบบสั่งซื้อ — แยกตามประเภทและเบอร์เสื้อ</p>
</header>

<div class="tables-grid">

  <!-- โปโลเหลือง -->
  <div class="card card--yellow">
    <div class="card-header">
      <div class="card-icon">👕</div>
      <div>
        <div class="card-title">เสื้อโปโลสีเหลือง</div>
        <div class="card-subtitle">polotype = โปโลสีเหลือง</div>
      </div>
    </div>
    <table>
      <thead><tr><th>เบอร์</th><th>จำนวน (ตัว)</th></tr></thead>
      <tbody>
        <% yellowPolo.forEach(item => { %>
          <tr>
            <td>เบอร์ <%= item.size %></td>
            <td>
              <% if (item.total === 0) { %>
                <span class="badge badge--zero">0</span>
              <% } else { %>
                <span class="badge badge--yellow"><%= item.total %></span>
              <% } %>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
    <div class="card-footer">
      <span>รวมทั้งหมด</span>
      <strong><%= yellowPolo.reduce((s, i) => s + i.total, 0) %> ตัว</strong>
    </div>
  </div>

  <!-- โปโลน้ำเงิน -->
  <div class="card card--navy">
    <div class="card-header">
      <div class="card-icon">👔</div>
      <div>
        <div class="card-title">เสื้อโปโลสีน้ำเงิน</div>
        <div class="card-subtitle">polotype = โปโลสีน้ำเงิน</div>
      </div>
    </div>
    <table>
      <thead><tr><th>เบอร์</th><th>จำนวน (ตัว)</th></tr></thead>
      <tbody>
        <% bluePolo.forEach(item => { %>
          <tr>
            <td>เบอร์ <%= item.size %></td>
            <td>
              <% if (item.total === 0) { %>
                <span class="badge badge--zero">0</span>
              <% } else { %>
                <span class="badge badge--navy"><%= item.total %></span>
              <% } %>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
    <div class="card-footer">
      <span>รวมทั้งหมด</span>
      <strong><%= bluePolo.reduce((s, i) => s + i.total, 0) %> ตัว</strong>
    </div>
  </div>

  <!-- เสื้อกีฬาโรงเรียน -->
  <div class="card card--green">
    <div class="card-header">
      <div class="card-icon">🏃</div>
      <div>
        <div class="card-title">เสื้อกีฬาโรงเรียน</div>
        <div class="card-subtitle">นับจาก schoolsite</div>
      </div>
    </div>
    <table>
      <thead><tr><th>เบอร์</th><th>จำนวน (ตัว)</th></tr></thead>
      <tbody>
        <% schoolShirt.forEach(item => { %>
          <tr>
            <td>เบอร์ <%= item.size %></td>
            <td>
              <% if (item.total === 0) { %>
                <span class="badge badge--zero">0</span>
              <% } else { %>
                <span class="badge badge--green"><%= item.total %></span>
              <% } %>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
    <div class="card-footer">
      <span>รวมทั้งหมด</span>
      <strong><%= schoolShirt.reduce((s, i) => s + i.total, 0) %> ตัว</strong>
    </div>
  </div>

</div>

</body>
</html>
